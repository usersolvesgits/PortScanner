<Window x:Class="PortScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PortScanner"
        mc:Ignorable="d"
        Title="Port Scanner" Icon="/Assets/Icons/windmill.ico"
        WindowStartupLocation="CenterScreen"
        Height="500" Width="1000" MinHeight="500" MinWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Menu Grid.Row="0">
			<MenuItem Header="Opzioni">
				<MenuItem Header="Esci" Click="Esci" InputGestureText="Alt + F4"/>
			</MenuItem>
			<MenuItem Header="Visualizza">
				<MenuItem Header="Temi">
					<MenuItem Header="Tema Chiaro" Click="Tema_Chiaro"/>
					<MenuItem Header="Tema Scuro" Click="Tema_Scuro"/>
                    <MenuItem Header="Tema di Sistema" Click="Tema_Sistema"/>
                </MenuItem>
                <MenuItem Header="Vecchio stile" Click="Tema_Vecchio"/>
            </MenuItem>
			<MenuItem Header="Altro">
                <MenuItem Header="FAQ">
                    <MenuItem Header="Cos'è un port scanner?" Click="FAQ_PortScanner"/>
                    <MenuItem Header="Che cos'è Sirius?" Click="FAQ_Sirius"/>
                    <MenuItem Header="Come funziona uno scanner di porte?" Click="FAQ_Funzionamento"/>
                    <MenuItem Header="È legale usare un port scanner?" Click="FAQ_Legale"/>
                </MenuItem>
                <MenuItem Header="Crediti">
                    <MenuItem Header="Lo sviluppatore" Click="Crediti_Sviluppatore"/>
                    <MenuItem Header="L'azienda" Click="Crediti_Azienda"/>
                </MenuItem>
            </MenuItem>
		</Menu>

		<Grid Grid.Row="1" Margin="10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="350"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0, 0, 5, 0"
							  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    
                    <StackPanel Grid.Column="0" Margin="15" VerticalAlignment="Top">
                        <TextBlock Text="Parametri Scansione" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <TextBlock Text="IP/Hostname:"/>
                        <TextBox Name="txtIPAddress" Margin="0,5,0,10" Text="localhost"/>

                        <TextBlock Text="Range Porte (incluse):"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBox Name="txtPortMin" Width="90" Margin="0,0,5,0"/>
                            <TextBlock Text="-" VerticalAlignment="Center"/>
                            <TextBox Name="txtPortMax" Width="90" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Timeout (ms):"/>
                        <TextBox Name="txtTimeout" Margin="0,5,0,10" Text="1000"/>

                        <Button Content="Avvia Scansione" Click="Scan_AvviaScansione" 
                                HorizontalAlignment="Stretch" Height="30" Margin="0,10,0,0"/>
                        <Button Content="Ferma Scansione" Click="Scan_FermaScansione" 
                                HorizontalAlignment="Stretch" Height="30" Margin="0,10,0,0"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Filtri / Ordinamento" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <CheckBox Name="chkAperte" Content="Mostra solo porte aperte" Margin="0,0,0,5"/>
                        <CheckBox Name="chkChiuse" Content="Mostra solo porte chiuse" Margin="0,0,0,10"/>
                        <ComboBox Name="cmbOrdina" Margin="0,0,0,5">
                            <ComboBoxItem Content="Numero Porta"/>
                            <ComboBoxItem Content="Stato Porta"/>
                        </ComboBox>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Esporta Risultati" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Name="btnEsportaCSV" Content="Esporta CSV" Click="Scan_EsportaCSV"
								    Height="30" Width="110" HorizontalAlignment="Stretch"/>

                            <TextBlock Text="Separatore:" VerticalAlignment="Center" Margin="10,0,5,0"/>

                            <TextBox Name="txtSeparatoreCSV" Text=";"
                                     Width="60" Height="30" 
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <Button Name="btnEsportaJSON" Content="Esporta JSON" Click="Scan_EsportaJSON" 
                                Height="30" Margin="0,5,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="1" Margin="10,0,0,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="150"/>
					</Grid.RowDefinitions>

					<DataGrid Name="dtgScansioni" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,10">
						<DataGrid.Columns>
							<DataGridTextColumn Header=" Stato" Binding="{Binding StatoPorta}" Width="*"/>
							<DataGridTextColumn Header=" Numero della Porta" Binding="{Binding NumeroPorta}" Width="2*"/>
                            <DataGridTextColumn Header=" Servizio Rilevato" Binding="{Binding Servizio}" Width="2*"/>
                        </DataGrid.Columns>
					</DataGrid>

					<StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
						<TextBlock Text="Statistiche Scansione" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
						<TextBlock Name="txtDurata" Text="Durata: 0 ms"/>
						<TextBlock Name="txtPorteTrovate" Text="Porte Aperte: 0"/>
						<TextBlock Name="txtTotalePorte" Text="Totale Porte Scansionate: 0"/>
					</StackPanel>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>