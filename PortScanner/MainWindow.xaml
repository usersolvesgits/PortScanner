<Window x:Class="PortScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PortScanner"
        mc:Ignorable="d"
        Title="Port Scanner" Icon="/Assets/Icons/lente_ingrandimento.ico"
        WindowStartupLocation="CenterScreen"
        Height="500" Width="1100" MinHeight="500" MinWidth="800"
        PreviewKeyDown="PortScanner_ShortCuts">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="Opzioni">
                <MenuItem Header="Scansione">
                    <MenuItem Header="Avvia Scansione" Click="Scan_AvviaScansione" InputGestureText="Ctrl + R"/>
                    <MenuItem Header="Ferma Scansione" Click="Scan_FermaScansione" InputGestureText="Ctrl + S"/>
                </MenuItem>
                <MenuItem Header="Esporta">
                    <MenuItem Header="Esporta CSV" Click="Esportazione_CSV" InputGestureText="Ctrl + Alt + C"/>
                    <MenuItem Header="Esporta JSON" Click="Esportazione_JSON" InputGestureText="Ctrl + Alt + J"/>
                </MenuItem>
                <MenuItem Header="Esci" Click="Esci" InputGestureText="Ctrl + Q"/>
            </MenuItem>
            <MenuItem Header="Visualizza">
                <MenuItem Header="Temi">
                    <MenuItem Header="Tema Chiaro" Click="Tema_Chiaro" InputGestureText="Ctrl + L"/>
                    <MenuItem Header="Tema Scuro" Click="Tema_Scuro" InputGestureText="Ctrl + D"/>
                    <MenuItem Header="Tema di Sistema" Click="Tema_Sistema"/>
                </MenuItem>
                <MenuItem Header="Vecchio stile" Click="Tema_Vecchio"/>
            </MenuItem>
            <MenuItem Header="Altro">
                <MenuItem Header="FAQ">
                    <MenuItem Header="Cos'è un port scanner?" Click="FAQ_PortScanner"/>
                    <MenuItem Header="Che cos'è Sirius?" Click="FAQ_Sirius"/>
                    <MenuItem Header="Come funziona uno scanner di porte?" Click="FAQ_Funzionamento"/>
                    <MenuItem Header="È legale usare un port scanner?" Click="FAQ_Legale"/>
                </MenuItem>
                <MenuItem Header="Crediti">
                    <MenuItem Header="Lo sviluppatore" Click="Crediti_Sviluppatore" InputGestureText="Ctrl + Alt + S"/>
                    <MenuItem Header="L'azienda" Click="Crediti_Azienda" InputGestureText="Ctrl + Alt + A"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" Margin="0, 0, 5, 0"
							  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Grid.Column="0" Margin="15" VerticalAlignment="Top">
                        <TextBlock Text="Parametri Scansione" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <TextBlock Text="IP/Hostname:"/>
                        <TextBox Name="txtIPAddress" Margin="0,5,0,10" Text="localhost"/>

                        <TextBlock Text="Range Porte (incluse):"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBox Name="txtPortMin" Width="90" Margin="0,0,5,0"/>
                            <TextBlock Text="-" VerticalAlignment="Center"/>
                            <TextBox Name="txtPortMax" Width="90" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Timeout stato porta (ms):"/>
                        <TextBox Name="txtTimeout" Margin="0,5,0,10" Text="100"/>

                        <Button Name="btnAvviaScansione" Content="Avvia Scansione" Click="Scan_AvviaScansione" 
                                HorizontalAlignment="Stretch" Height="30" Margin="0,10,0,0" Cursor="Hand"/>
                        <Button Content="Ferma Scansione" Click="Scan_FermaScansione" 
                                HorizontalAlignment="Stretch" Height="30" Margin="0,10,0,0" Cursor="Hand"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Filtri / Ordinamento" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="Filtra per:"/>
                        <ComboBox Name="cmbFiltri" Margin="0,0,0,5" 
                                  SelectionChanged="OpzioniScansione_CambioFiltro" PreviewMouseWheel="OpzioniScansione_MouseWheel">
                            <ComboBoxItem Content="Nessun Filtro" IsSelected="True"/>
                            <ComboBoxItem Content="Porte Aperte"/>
                            <ComboBoxItem Content="Porte Chiuse"/>
                            <ComboBoxItem Content="Servizi Rilevati"/>
                        </ComboBox>
                        <TextBlock Text="Ordina per:"/>
                        <ComboBox Name="cmbOrdina" Margin="0,0,0,5" 
                                  SelectionChanged="OpzioniScansione_CambioOrdinamento" PreviewMouseWheel="OpzioniScansione_MouseWheel">
                            <ComboBoxItem Content="Nessun Ordinamento" IsSelected="True"/>
                            <ComboBoxItem Content="Stato Porta (Aperte - Chiuse)"/>
                            <ComboBoxItem Content="Stato Porta (Chiuse - Aperte)"/>
                        </ComboBox>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Esporta Risultati" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Name="btnEsportaCSV" Content="Esporta CSV" Click="Esportazione_CSV"
								    Height="30" Width="110" HorizontalAlignment="Stretch" Cursor="Hand"/>

                            <TextBlock Text="Separatore:" VerticalAlignment="Center" Margin="10,0,5,0"/>

                            <TextBox Name="txtSeparatoreCSV" Text=";"
                                     Margin="10, 0, 0, 0" Height="30" Width="100"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <Button Name="btnEsportaJSON" Content="Esporta JSON" Click="Esportazione_JSON" 
                                Height="30" Margin="0,5,0,0" HorizontalAlignment="Stretch" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>

                    <DataGrid Name="dtgScansioni" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Stato (Icona)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="20" Height="20" x:Name="ellipse"/>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsOpen}" Value="True">
                                                <Setter TargetName="ellipse" Property="Fill" Value="Green"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsOpen}" Value="False">
                                                <Setter TargetName="ellipse" Property="Fill" Value="Red"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Stato" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Chiusa"/>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsOpen}" Value="True">
                                                <Setter Property="TextBlock.Text" Value="Aperta"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header=" Numero della Porta" Binding="{Binding NumeroPorta}" Width="2*"/>
                            <DataGridTextColumn Header=" Servizio Rilevato" Binding="{Binding Servizio}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
                        <TextBlock Text="Statistiche Scansione" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <TextBlock Text="Progresso della scansione:"/>
                        <ProgressBar Name="prbProgressoScan" Height="10" IsIndeterminate="False"
                                     Minimum="0" Maximum="100" Margin="0, 0, 0, 10"/>
                        <TextBlock Name="txtDurata" Text="Durata: 0 ms"/>
                        <TextBlock Name="txtPorteAperte" Text="Porte Aperte: 0"/>
                        <TextBlock Name="txtPorteScansionate" Text="Porte Totali Scansionate: 0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>